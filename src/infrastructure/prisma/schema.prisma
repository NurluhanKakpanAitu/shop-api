generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
  SELLER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      UserRole @default(USER)
  products  Product[]
}

model Product {
  id             String   @id @default(uuid())
  nameKz         String
  nameEn         String
  nameRu         String
  descriptionKz  String
  descriptionEn  String
  descriptionRu  String
  price          Float
  imageUrl       String
  ownerId        String
  owner          User     @relation(fields: [ownerId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
